<Window x:Class="PomodoroTimer.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource SettingsTitle}"
        Height="430" Width="420"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
    Background="#2A1742"
    Opacity="0.95"
        FontFamily="Segoe UI"
        ShowInTaskbar="False">

    <Window.Resources>
        <Style x:Key="DlgButton" TargetType="Button">
            <Setter Property="Background" Value="#AA2A1D48"/>
            <Setter Property="Foreground" Value="#FFEAD8FF"/>
            <Setter Property="BorderBrush" Value="#66FFD27A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="MinWidth" Value="90"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#CC4D2776"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#CC9C2D4C"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#FFF7EED4"/>
            <Setter Property="Foreground" Value="#000000"/>
            <Setter Property="BorderBrush" Value="#88B08A56"/>
            <Setter Property="Height" Value="21"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="6,0"/>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#000000"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
    </Window.Resources>

    <Border Margin="14"
            Padding="10"
            Background="#8C2A1742"
            BorderBrush="#66FFD27A"
            BorderThickness="1"
            CornerRadius="12">
    <Grid Margin="24,20,24,10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Section header -->
        <TextBlock Grid.Row="0"
                   Text="{DynamicResource SettingsSoundSection}"
                   Foreground="#FFE6D4F8"
                   FontSize="11" FontWeight="Bold"/>

        <!-- Sound selector row -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <ComboBox x:Name="CbSounds"
                      Grid.Column="0"
                      DisplayMemberPath="Name"
                      SelectionChanged="CbSounds_SelectionChanged"/>

            <Button Grid.Column="2"
                    Style="{StaticResource DlgButton}"
                    Content="{DynamicResource SettingsBtnTest}"
                    MinWidth="80"
                    Click="BtnTest_Click"/>
        </Grid>

        <!-- Hint text -->
        <TextBlock Grid.Row="3"
                   x:Name="TbHint"
                   Foreground="#FFD1BCD8"
                   FontSize="10"
                   Margin="0,6,0,6"
                   TextWrapping="Wrap"/>

        <!-- Autostart checkbox -->
        <CheckBox x:Name="ChkAutostart"
                  Grid.Row="4"
                  Foreground="#FFE6D4F8"
                  FontSize="12"
                  Content="{DynamicResource SettingsChkAutostart}"
                  Margin="0,0,0,0"/>

        <!-- Always on Top checkbox -->
        <CheckBox x:Name="ChkAlwaysOnTop"
                  Grid.Row="6"
                  Foreground="#FFE6D4F8"
                  FontSize="12"
                  Content="{DynamicResource SettingsChkAlwaysOnTop}"
                  Margin="0,0,0,0"/>

        <!-- Silent mode checkbox -->
        <CheckBox x:Name="ChkSilentMode"
                  Grid.Row="7"
                  Foreground="#FFE6D4F8"
                  FontSize="12"
                  Content="{DynamicResource SettingsChkSilentMode}"
                  Margin="0,6,0,0"/>

        <!-- Language section header -->
        <StackPanel Grid.Row="9" Orientation="Horizontal">
            <TextBlock Text="🌐  A-文  "
                       Foreground="#FFE6D4F8"
                       FontSize="11" FontWeight="Bold"/>
            <TextBlock Text="{DynamicResource SettingsLangSection}"
                       Foreground="#FFE6D4F8"
                       FontSize="11" FontWeight="Bold"/>
        </StackPanel>

        <!-- Language selector -->
        <ComboBox x:Name="CbLanguage"
                  Grid.Row="11"/>

        <!-- OK / Cancel -->
        <StackPanel Grid.Row="14" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Style="{StaticResource DlgButton}"
                    Content="{DynamicResource BtnCancelLabel}"
                    Margin="0,0,10,0"
                    Click="BtnCancel_Click"/>
            <Button Style="{StaticResource DlgButton}"
                    Content="{DynamicResource BtnOkLabel}"
                    Foreground="#FFD3FFAE"
                    Click="BtnOk_Click"/>
        </StackPanel>
    </Grid>
    </Border>
</Window>

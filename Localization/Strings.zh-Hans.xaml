<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- Tooltips -->
    <sys:String x:Key="TipCompact">紧凑模式</sys:String>
    <sys:String x:Key="TipFull">完整模式</sys:String>
    <sys:String x:Key="TipSettings">设置</sys:String>
    <sys:String x:Key="TipMinimize">最小化</sys:String>
    <sys:String x:Key="TipHide">隐藏到托盘</sys:String>

    <!-- Main window labels -->
    <sys:String x:Key="LblMinutes">分钟</sys:String>
    <sys:String x:Key="LblPresets">预设:</sys:String>
    <sys:String x:Key="MinSuffix"> 分</sys:String>

    <!-- Buttons -->
    <sys:String x:Key="BtnStartLabel">开始</sys:String>
    <sys:String x:Key="BtnStopLabel">暂停</sys:String>
    <sys:String x:Key="BtnResetLabel">重置</sys:String>

    <!-- Settings window -->
    <sys:String x:Key="SettingsTitle">设置 — Pomodoro Timer</sys:String>
    <sys:String x:Key="SettingsSoundSection">完成提示音</sys:String>
    <sys:String x:Key="SettingsBtnTest">▶  测试</sys:String>
    <sys:String x:Key="SettingsChkAutostart">随 Windows 启动</sys:String>
    <sys:String x:Key="SettingsChkAlwaysOnTop">置顶显示（70% 透明度）</sys:String>
    <sys:String x:Key="SettingsChkSilentMode">静音模式（闪烁代替声音）</sys:String>
    <sys:String x:Key="SettingsLangSection">界面语言</sys:String>
    <sys:String x:Key="BtnOkLabel">确定</sys:String>
    <sys:String x:Key="BtnCancelLabel">取消</sys:String>

    <!-- Tray menu -->
    <sys:String x:Key="TrayShow">显示</sys:String>
    <sys:String x:Key="TraySettings">设置</sys:String>
    <sys:String x:Key="TrayExit">退出</sys:String>

    <!-- Hints / dynamic text -->
    <sys:String x:Key="HintDefault">将使用默认 Windows 系统声音。</sys:String>
    <sys:String x:Key="SoundDefault">(系统 — Exclamation)</sys:String>

</ResourceDictionary>

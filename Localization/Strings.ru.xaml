<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- Tooltips -->
    <sys:String x:Key="TipCompact">Компактный режим</sys:String>
    <sys:String x:Key="TipFull">Полный режим</sys:String>
    <sys:String x:Key="TipSettings">Настройки</sys:String>
    <sys:String x:Key="TipMinimize">Свернуть</sys:String>
    <sys:String x:Key="TipHide">Скрыть в трей</sys:String>

    <!-- Main window labels -->
    <sys:String x:Key="LblMinutes">минуты</sys:String>
    <sys:String x:Key="LblPresets">Шаблоны:</sys:String>
    <sys:String x:Key="MinSuffix"> мин</sys:String>

    <!-- Buttons -->
    <sys:String x:Key="BtnStartLabel">СТАРТ</sys:String>
    <sys:String x:Key="BtnStopLabel">СТОП</sys:String>
    <sys:String x:Key="BtnResetLabel">СБРОС</sys:String>

    <!-- Settings window -->
    <sys:String x:Key="SettingsTitle">Настройки — Pomodoro Timer</sys:String>
    <sys:String x:Key="SettingsSoundSection">ЗВУКОВОЙ СИГНАЛ ПО ЗАВЕРШЕНИИ</sys:String>
    <sys:String x:Key="SettingsBtnTest">▶  Тест</sys:String>
    <sys:String x:Key="SettingsChkAutostart">Запускать при старте Windows</sys:String>
    <sys:String x:Key="SettingsChkAlwaysOnTop">Поверх всех окон (прозрачность 70%)</sys:String>
    <sys:String x:Key="SettingsChkSilentMode">Тихий режим (мигание вместо звука)</sys:String>
    <sys:String x:Key="SettingsLangSection">ЯЗЫК ИНТЕРФЕЙСА</sys:String>
    <sys:String x:Key="BtnOkLabel">ОК</sys:String>
    <sys:String x:Key="BtnCancelLabel">Отмена</sys:String>

    <!-- Tray menu -->
    <sys:String x:Key="TrayShow">Показать</sys:String>
    <sys:String x:Key="TraySettings">Настройки</sys:String>
    <sys:String x:Key="TrayExit">Выход</sys:String>

    <!-- Hints / dynamic text -->
    <sys:String x:Key="HintDefault">Будет использован стандартный системный звук Windows.</sys:String>
    <sys:String x:Key="SoundDefault">(Системный — Exclamation)</sys:String>

</ResourceDictionary>

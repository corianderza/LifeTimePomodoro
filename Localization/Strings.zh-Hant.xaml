<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- Tooltips -->
    <sys:String x:Key="TipCompact">緊湊模式</sys:String>
    <sys:String x:Key="TipFull">完整模式</sys:String>
    <sys:String x:Key="TipSettings">設定</sys:String>
    <sys:String x:Key="TipMinimize">最小化</sys:String>
    <sys:String x:Key="TipHide">隱藏到系統匣</sys:String>

    <!-- Main window labels -->
    <sys:String x:Key="LblMinutes">分鐘</sys:String>
    <sys:String x:Key="LblPresets">預設:</sys:String>
    <sys:String x:Key="MinSuffix"> 分</sys:String>

    <!-- Buttons -->
    <sys:String x:Key="BtnStartLabel">開始</sys:String>
    <sys:String x:Key="BtnStopLabel">暫停</sys:String>
    <sys:String x:Key="BtnResetLabel">重設</sys:String>

    <!-- Settings window -->
    <sys:String x:Key="SettingsTitle">設定 — Pomodoro Timer</sys:String>
    <sys:String x:Key="SettingsSoundSection">完成提示音</sys:String>
    <sys:String x:Key="SettingsBtnTest">▶  測試</sys:String>
    <sys:String x:Key="SettingsChkAutostart">隨 Windows 啟動</sys:String>
    <sys:String x:Key="SettingsChkAlwaysOnTop">置頂顯示（70% 透明度）</sys:String>
    <sys:String x:Key="SettingsChkSilentMode">靜音模式（閃爍代替聲音）</sys:String>
    <sys:String x:Key="SettingsLangSection">介面語言</sys:String>
    <sys:String x:Key="BtnOkLabel">確定</sys:String>
    <sys:String x:Key="BtnCancelLabel">取消</sys:String>

    <!-- Tray menu -->
    <sys:String x:Key="TrayShow">顯示</sys:String>
    <sys:String x:Key="TraySettings">設定</sys:String>
    <sys:String x:Key="TrayExit">結束</sys:String>

    <!-- Hints / dynamic text -->
    <sys:String x:Key="HintDefault">將使用預設 Windows 系統聲音。</sys:String>
    <sys:String x:Key="SoundDefault">（系統 — Exclamation）</sys:String>

</ResourceDictionary>

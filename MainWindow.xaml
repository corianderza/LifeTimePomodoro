<Window x:Class="PomodoroTimer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Pomodoro Timer"
        Icon="/Assets/ico/32.ico"
    Height="460" Width="460"
    MinHeight="460" MinWidth="460"
    MaxHeight="460" MaxWidth="460"
    Background="Transparent"
    AllowsTransparency="True"
    WindowStyle="None"
    ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI"
        Closing="Window_Closing">

    <Window.Resources>
        <!-- DSEG7 digital font -->
        <FontFamily x:Key="DigitalFont">pack://application:,,,/Fonts/DSEG7Classic-Regular.ttf#DSEG7 Classic</FontFamily>

        <!-- Rounded action button style -->
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Background" Value="#AA2A1D48"/>
            <Setter Property="Foreground" Value="#FFEAD8FF"/>
            <Setter Property="BorderBrush" Value="#66FFD27A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#CC4D2776"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="#88FFE38F"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#CC9C2D4C"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="#88FFD27A"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Preset button style -->
        <Style x:Key="PresetButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
            <Setter Property="Height" Value="24"/>
            <Setter Property="Width" Value="56"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Foreground" Value="#FFD7F0FF"/>
        </Style>

        <!-- Arrow RepeatButton style -->
        <Style x:Key="ArrowButton" TargetType="RepeatButton">
            <Setter Property="Background" Value="#AA2A1D48"/>
            <Setter Property="Foreground" Value="#FFD7F0FF"/>
            <Setter Property="BorderBrush" Value="#66FFD27A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Width" Value="27"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Delay" Value="400"/>
            <Setter Property="Interval" Value="80"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#CC4D2776"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#CC9C2D4C"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WindowChromeButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
            <Setter Property="Width" Value="24"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,0,3,0"/>
        </Style>

        <Style x:Key="CompactChromeButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
            <Setter Property="Width" Value="20"/>
            <Setter Property="Height" Value="20"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,0,2,0"/>
        </Style>

        <Style x:Key="CompactActionButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
            <Setter Property="Height" Value="20"/>
            <Setter Property="FontSize" Value="8"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid x:Name="ContentGrid" Margin="30">
        <Image x:Name="ImgBackground" Source="/Assets/bkg/Pom400x400.png" Stretch="Fill">
            <Image.Effect>
                <DropShadowEffect Color="#FFFF5500" BlurRadius="28" ShadowDepth="0" Opacity="0"/>
            </Image.Effect>
        </Image>

        <Grid x:Name="PanelFull" Margin="56,38,56,45">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,8">
                <TextBlock Text=" "
                           Foreground="#6b576d"
                           FontSize="10"
                           FontWeight="Bold"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Left"
                           Margin="-56,0,0,0"/>

                <Border Background="#00000000"
                        Height="114"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Center"
                        Margin="-36,-40,-32,0"
                        MouseLeftButtonDown="DragArea_MouseLeftButtonDown"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            VerticalAlignment="Top" Margin="0,-36,10,0">
                    <Button x:Name="BtnCompact"
                            Style="{StaticResource WindowChromeButton}"
                            Content="⊟"
                            ToolTip="{DynamicResource TipCompact}"
                            Click="BtnCompact_Click"/>
                    <Button x:Name="BtnSettings"
                            Style="{StaticResource WindowChromeButton}"
                            Content="⚙"
                            FontSize="12"
                            ToolTip="{DynamicResource TipSettings}"
                            Click="BtnSettings_Click"/>
                    <Button x:Name="BtnMinimize"
                            Style="{StaticResource WindowChromeButton}"
                            Content="_"
                            ToolTip="{DynamicResource TipMinimize}"
                            Click="BtnMinimize_Click"/>
                    <Button x:Name="BtnHide"
                            Style="{StaticResource WindowChromeButton}"
                            Content="✕"
                            Margin="0"
                            ToolTip="{DynamicResource TipHide}"
                            Click="BtnHide_Click"/>
                </StackPanel>
            </Grid>

            <Border Grid.Row="1"
                    Background="#8C2A1742"
                    CornerRadius="11"
                    BorderBrush="#66FFD27A"
                    BorderThickness="1"
                    Padding="2,6,2,11"
                    Margin="0,0,0,0">
                <StackPanel>
                    <Grid HorizontalAlignment="Center">
                        <!-- Ghost layer: always-visible dim segments for digital dial effect -->
                        <TextBlock Text="00:00"
                                   FontFamily="{StaticResource DigitalFont}"
                                   FontSize="66"
                                   Foreground="#FFFFF2CD"
                                   Opacity="0.10"
                                   HorizontalAlignment="Center"
                                   IsHitTestVisible="False"/>
                        <TextBlock x:Name="TbDisplay"
                                   Text="00:00"
                                   FontFamily="{StaticResource DigitalFont}"
                                   FontSize="66"
                                   Foreground="#FFFFF2CD"
                                   HorizontalAlignment="Center">
                            <TextBlock.Effect>
                                <DropShadowEffect Color="#FFFF9D4A" BlurRadius="18"
                                                  ShadowDepth="0" Opacity="0.8"/>
                            </TextBlock.Effect>
                        </TextBlock>
                    </Grid>

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Margin="0,8,0,2">
                        <RepeatButton x:Name="BtnMinDown"
                                      Style="{StaticResource ArrowButton}"
                                      Content="▼"
                                      Click="BtnMinDown_Click"/>
                        <TextBlock Text="{DynamicResource LblMinutes}"
                                   Foreground="#FFE6D4F8"
                                   FontSize="9"
                                   VerticalAlignment="Center"
                                   Margin="10,0"/>
                        <RepeatButton x:Name="BtnMinUp"
                                      Style="{StaticResource ArrowButton}"
                                      Content="▲"
                                      Click="BtnMinUp_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="{DynamicResource LblPresets}"
                           Foreground="#FFE6D4F8"
                           FontSize="9"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"/>
                <Button x:Name="BtnPreset15" Style="{StaticResource PresetButton}"
                        Click="BtnPreset_Click" Tag="15" Margin="2,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="15"/>
                        <TextBlock Text="{DynamicResource MinSuffix}"/>
                    </StackPanel>
                </Button>
                <Button x:Name="BtnPreset30" Style="{StaticResource PresetButton}"
                        Click="BtnPreset_Click" Tag="30" Margin="2,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="30"/>
                        <TextBlock Text="{DynamicResource MinSuffix}"/>
                    </StackPanel>
                </Button>
                <Button x:Name="BtnPreset45" Style="{StaticResource PresetButton}"
                        Click="BtnPreset_Click" Tag="45" Margin="2,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="45"/>
                        <TextBlock Text="{DynamicResource MinSuffix}"/>
                    </StackPanel>
                </Button>
            </StackPanel>

            <Grid Grid.Row="5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="6"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="6"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="BtnStart" Grid.Column="0"
                        Style="{StaticResource ActionButton}"
                        Foreground="#FFD3FFAE" FontWeight="SemiBold"
                        Click="BtnStart_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="▶" Margin="0,0,4,0"/>
                        <TextBlock Text="{DynamicResource BtnStartLabel}"/>
                    </StackPanel>
                </Button>

                <Button x:Name="BtnStop" Grid.Column="2"
                        Style="{StaticResource ActionButton}"
                        Foreground="#FFFFE0A6" FontWeight="SemiBold"
                        IsEnabled="False"
                        Click="BtnStop_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⏸" Margin="0,0,4,0"/>
                        <TextBlock Text="{DynamicResource BtnStopLabel}"/>
                    </StackPanel>
                </Button>

                <Button x:Name="BtnReset" Grid.Column="4"
                        Style="{StaticResource ActionButton}"
                        Foreground="#FFFFC1C1" FontWeight="SemiBold"
                        Click="BtnReset_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="↺" Margin="0,0,4,0"/>
                        <TextBlock Text="{DynamicResource BtnResetLabel}"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Grid>

        <!-- Compact 200×200 panel -->
        <Grid x:Name="PanelCompact" Visibility="Collapsed" Margin="28,19,28,22">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="5"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,4">
                <Border Background="#00000000"
                        Height="57"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Center"
                        Margin="-18,-20,-16,0"
                        MouseLeftButtonDown="DragArea_MouseLeftButtonDown"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            VerticalAlignment="Top" Margin="0,-18,-5,0">
                    <Button Style="{StaticResource CompactChromeButton}"
                            Content="⊞"
                            ToolTip="{DynamicResource TipFull}"
                            Click="BtnCompact_Click"/>
                    <Button Style="{StaticResource CompactChromeButton}"
                            Content="_"
                            ToolTip="{DynamicResource TipMinimize}"
                            Click="BtnMinimize_Click"/>
                    <Button Style="{StaticResource CompactChromeButton}"
                            Margin="0"
                            Content="✕"
                            ToolTip="{DynamicResource TipHide}"
                            Click="BtnHide_Click"/>
                </StackPanel>
            </Grid>

            <Border Grid.Row="1"
                    Background="#8C2A1742"
                    CornerRadius="6"
                    BorderBrush="#66FFD27A"
                    BorderThickness="1"
                    Padding="1,3,1,5"
                    Margin="0,15,0,0">
                <Grid HorizontalAlignment="Center">
                    <TextBlock Text="00:00"
                               FontFamily="{StaticResource DigitalFont}"
                               FontSize="33"
                               Foreground="#FFFFF2CD"
                               Opacity="0.10"
                               HorizontalAlignment="Center"
                               IsHitTestVisible="False"/>
                    <TextBlock x:Name="TbDisplayCompact"
                               Text="00:00"
                               FontFamily="{StaticResource DigitalFont}"
                               FontSize="33"
                               Foreground="#FFFFF2CD"
                               HorizontalAlignment="Center">
                        <TextBlock.Effect>
                            <DropShadowEffect Color="#FFFF9D4A" BlurRadius="9"
                                              ShadowDepth="0" Opacity="0.8"/>
                        </TextBlock.Effect>
                    </TextBlock>
                </Grid>
            </Border>

            <Grid Grid.Row="3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="4"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="BtnStartCompact" Grid.Column="0"
                        Style="{StaticResource CompactActionButton}"
                        Foreground="#FFD3FFAE" FontWeight="SemiBold"
                        Click="BtnStart_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#x25B6;" Margin="0,0,2,0"/>
                        <TextBlock Text="{DynamicResource BtnStartLabel}"/>
                    </StackPanel>
                </Button>

                <Button x:Name="BtnStopCompact" Grid.Column="2"
                        Style="{StaticResource CompactActionButton}"
                        Foreground="#FFFFE0A6" FontWeight="SemiBold"
                        IsEnabled="False"
                        Click="BtnStop_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#x23F8;" Margin="0,0,2,0"/>
                        <TextBlock Text="{DynamicResource BtnStopLabel}"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Grid>
        </Grid>
    </Grid>
</Window>
